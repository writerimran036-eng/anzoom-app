// lib/main.dart
import 'package:flutter/material.dart';
import 'package:firebase_core/firebase_core.dart';
import 'package:firebase_storage/firebase_storage.dart';
import 'package:image_picker/image_picker.dart';
import 'dart:io';
import 'firebase_options.dart'; // Firebase setup ke time generate hoti hai

void main() async {
  WidgetsFlutterBinding.ensureInitialized();
  await Firebase.initializeApp(
    options: DefaultFirebaseOptions.currentPlatform,
  );
  runApp(MyApp());
}

class MyApp extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      title: 'AnZoom App',
      theme: ThemeData(primarySwatch: Colors.purple),
      home: UploadPage(),
    );
  }
}

class UploadPage extends StatefulWidget {
  @override
  _UploadPageState createState() => _UploadPageState();
}

class _UploadPageState extends State<UploadPage> {
  final FirebaseStorage storage = FirebaseStorage.instance;
  final ImagePicker picker = ImagePicker();

  Future<void> uploadFile() async {
    // Phone se image/video select karo
    final XFile? file = await picker.pickImage(source: ImageSource.gallery);
    if (file == null) return;

    File localFile = File(file.path);

    try {
      // Firebase Storage me folder ke andar upload
      String fileName = file.name;
      await storage.ref('chat_photos/$fileName').putFile(localFile);

      ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text('File uploaded successfully')));
    } catch (e) {
      print(e);
      ScaffoldMessenger.of(context).showSnackBar(
          SnackBar(content: Text('Upload failed: $e')));
    }
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(title: Text('AnZoom Upload')),
      body: Center(
        child: ElevatedButton(
          onPressed: uploadFile,
          child: Text('Upload Image/Video'),
        ),
      ),
    );
  }
}